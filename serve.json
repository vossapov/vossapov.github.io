{
  "cleanUrls": false,
  "directoryListing": false,
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/index", "destination": "/index.html" },
    { "source": "/project", "destination": "/project.html" }
  ],
  "headers": [
    {
      "source": "**/*.@(html|css|js)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    }
  ]
}
